# =============================================================================
# EasyTax Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=easytax
DB_USER=easytax
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=prefer

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
JWT_SIGNING_KEY=change-me-to-a-different-secret

# Field-level encryption key (Fernet-compatible, generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=change-me-generate-with-fernet

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# SSL (set True in production)
SECURE_SSL_REDIRECT=False

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@easytax.com

# Stripe
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# AWS S3 (Document Vault)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=easytax-documents
AWS_S3_REGION=us-east-1

# reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Frontend
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_STRIPE_PK=pk_test_your_test_key_here
